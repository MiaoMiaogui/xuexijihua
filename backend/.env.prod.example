# ===== 生产环境配置模板 =====
# 复制为 .env.prod 后，把 DB_PASS / JWT_SECRET 改成强随机值：
#   DB_PASS=$(openssl rand -base64 18)
#   JWT_SECRET=$(openssl rand -hex 32)

# ===== 服务 =====
PORT=4000
NODE_ENV=production

# ===== MySQL（与 docker-compose.prod.yml 中 mysql 服务保持一致）=====
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASS=change-me-strong-password
DB_NAME=study_app
DB_DRIVER=mysql

# ===== Redis（容器内部网络，无密码即可）=====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=

# ===== JWT（务必改！否则令牌可被伪造）=====
JWT_SECRET=change-me-to-a-long-random-string

# ===== OCR 服务（默认 mock，无需密钥）=====
# mock | tesseract | tencent | baidu | cloud
OCR_PROVIDER=mock
OCR_API_URL=
OCR_API_KEY=
OCR_API_SECRET=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ===== AI 对话式计划生成（默认 mock）=====
# mock | openai
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
